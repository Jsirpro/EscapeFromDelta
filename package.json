{
  "name": "escape-from-delta",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "app",
    "clients"
  ],
  "scripts": {
    "dev": "npm --workspace app run dev",
    "generate:client": "npm --workspace clients run generate",
    "test:program": "vitest run tests/program",
    "test:client": "npm --workspace clients run test",
    "test:app": "npm --workspace app run test",
    "query:records": "npm --workspace clients run query:records",
    "demo:local": "npm --workspace clients run demo:local",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1"
  }
}
